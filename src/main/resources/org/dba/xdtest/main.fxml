<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="640.0" prefWidth="1000.0" spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.dba.xdtest.MainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <AnchorPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="845.0" styleClass="root" stylesheets="@../../../css/style.css">
        <Label fx:id="labelJDK" layoutX="574.0" layoutY="562.0" prefHeight="17.0" prefWidth="355.0" text="JavaSDK" />
        <Label fx:id="labelJavaFX" layoutX="574.0" layoutY="543.0" prefHeight="17.0" prefWidth="269.0" text="JavaFX" />

        <Label fx:id="labelSourceFile" layoutX="172.0" layoutY="34.0" prefHeight="35.0" prefWidth="199.0" textFill="#1361f2">
         <font>
            <Font size="24.0" />
         </font></Label>

        <Label fx:id="labelTargetFile" layoutX="218.0" layoutY="110.0" prefHeight="20.0" prefWidth="549.0" textFill="#1361f2">
         <font>
            <Font size="18.0" />
         </font></Label>

        <Button fx:id="buttonCompare" layoutX="644.0" layoutY="37.0" mnemonicParsing="false" onAction="#handleCompare" prefHeight="30.0" prefWidth="87.0" stylesheets="@../../../css/style.css" text="Compare" />
        <Button fx:id="buttonTarget" layoutX="442.0" layoutY="36.0" mnemonicParsing="false" onAction="#handleOpenTargetFile" stylesheets="@../../../css/style.css" text="Select Target">
            <font>
                <Font size="14.0" />
            </font>
        </Button>
        <Button fx:id="buttonQuit" layoutX="830.0" layoutY="35.0" mnemonicParsing="false" onAction="#handleQuit" stylesheets="@../../../css/style.css" text="Quit" />
        <RadioButton fx:id="radioRack" layoutX="45.0" layoutY="30.0" mnemonicParsing="false" onAction="#sourceSelect" selected="true" stylesheets="@../../../css/style.css" text="Rack">
            <toggleGroup>
                <ToggleGroup fx:id="confGroup" />
            </toggleGroup>
            <font>
                <Font size="14.0" />
            </font>
        </RadioButton>
        <RadioButton fx:id="radioMotivairCDU" layoutX="45.0" layoutY="70.0" mnemonicParsing="false" onAction="#sourceSelect" stylesheets="@../../../css/style.css" text="Motivair CDU" toggleGroup="$confGroup">
            <font>
                <Font size="14.0" />
            </font>
        </RadioButton>
        <RadioButton fx:id="radioVertivCDU" layoutX="45.0" layoutY="114.0" mnemonicParsing="false" onAction="#sourceSelect" stylesheets="@../../../css/style.css" text="Vertiv CDU" toggleGroup="$confGroup">
            <font>
                <Font size="14.0" />
            </font>
        </RadioButton>
        <RadioButton fx:id="radioParts" layoutX="44.0" layoutY="153.0" mnemonicParsing="false" onAction="#sourceSelect" stylesheets="@../../../css/style.css" text="Parts" toggleGroup="$confGroup">
            <font>
                <Font size="14.0" />
            </font>
        </RadioButton>
        <Label fx:id="labelStatus" layoutX="37.0" layoutY="535.0" prefHeight="17.0" prefWidth="269.0" text="Status">
         <font>
            <Font size="24.0" />
         </font></Label>
        <TableView fx:id="tableDiff" layoutX="37.0" layoutY="218.0" maxWidth="800.0" prefHeight="294.0" prefWidth="800.0">
            <columns>
                <TableColumn fx:id="skuCol" prefWidth="200.0" resizable="false" text="SKU" />
                <TableColumn fx:id="sourceItemCol" prefWidth="100.0" resizable="false" />
                <TableColumn fx:id="targetItemCol" prefWidth="100.0" resizable="false" text=" " />
                <TableColumn fx:id="sourceQtyCol" prefWidth="100.0" resizable="false" text=" " />
                <TableColumn fx:id="targetQtyCol" prefWidth="100.0" resizable="false" text=" " />
                <TableColumn fx:id="sourceSolIDCol" prefWidth="100.0" resizable="false" text=" " />
                <TableColumn fx:id="targetSolIDCol" prefWidth="100.0" resizable="false" text=" " />
            </columns>
        </TableView>

    </AnchorPane>
</VBox>
